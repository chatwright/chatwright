{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatwright.dev/formats/run-bundle/v1/schema.json",
  "$defs": {
    "ActorActionOutcome": {
      "properties": {
        "Kind": {
          "type": "string",
          "enum": [
            "skipped-invalid",
            "executed",
            "executed-no-effect",
            "resolution-failed",
            "task-completed",
            "task-given-up"
          ]
        },
        "Detail": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "Kind",
        "Detail"
      ]
    },
    "ActorLoopEvent": {
      "properties": {
        "Index": {
          "type": "integer"
        },
        "At": {
          "type": "string",
          "format": "date-time"
        },
        "TaskID": {
          "type": "string"
        },
        "ObservationSequence": {
          "type": "integer"
        },
        "Proposal": {
          "$ref": "#/$defs/ActorProposal"
        },
        "Usage": {
          "$ref": "#/$defs/ActorUsage"
        },
        "Validation": {
          "$ref": "#/$defs/ActorValidationOutcome"
        },
        "Action": {
          "$ref": "#/$defs/ActorActionOutcome"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "Index",
        "At",
        "TaskID",
        "ObservationSequence",
        "Proposal",
        "Usage",
        "Validation",
        "Action"
      ]
    },
    "ActorProposal": {
      "properties": {
        "Kind": {
          "type": "string",
          "enum": [
            "send-text",
            "click",
            "task-done",
            "give-up"
          ]
        },
        "Text": {
          "type": "string"
        },
        "ActionID": {
          "type": "string"
        },
        "ObservationSequence": {
          "type": "integer"
        },
        "Rationale": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "Kind",
        "Text",
        "ActionID",
        "ObservationSequence",
        "Rationale"
      ]
    },
    "ActorUsage": {
      "properties": {
        "Model": {
          "type": "string"
        },
        "InputTokens": {
          "type": "integer"
        },
        "OutputTokens": {
          "type": "integer"
        },
        "Latency": {
          "type": "integer"
        },
        "cost": {
          "type": "number"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "Model",
        "InputTokens",
        "OutputTokens",
        "Latency"
      ]
    },
    "ActorValidationOutcome": {
      "properties": {
        "Checked": {
          "type": "boolean"
        },
        "Verdict": {
          "type": "string",
          "enum": [
            "",
            "fresh",
            "stale"
          ]
        },
        "Reason": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "Checked",
        "Verdict",
        "Reason"
      ]
    },
    "BundleAIGoalSection": {
      "properties": {
        "goal": {
          "$ref": "#/$defs/GoalGoal"
        },
        "actorId": {
          "type": "string"
        },
        "events": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/ActorLoopEvent"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "observations": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/BundleRetainedObservation"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "report": {
          "$ref": "#/$defs/CampaignReport"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/DatastateEvidence"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "goal",
        "actorId",
        "events",
        "observations",
        "report"
      ]
    },
    "BundleActor": {
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "platformIdentities": {
          "additionalProperties": {
            "$ref": "#/$defs/BundlePlatformIdentity"
          },
          "type": "object"
        },
        "provider": {
          "$ref": "#/$defs/BundleActorProvider"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "type"
      ]
    },
    "BundleActorProvider": {
      "properties": {
        "name": {
          "type": "string"
        },
        "modelIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "BundleAnchor": {
      "properties": {
        "chatId": {
          "type": "integer"
        },
        "entryIndex": {
          "type": "integer"
        },
        "messageId": {
          "type": "integer"
        },
        "version": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "chatId",
        "entryIndex"
      ]
    },
    "BundleAnnotation": {
      "properties": {
        "id": {
          "type": "string"
        },
        "anchor": {
          "$ref": "#/$defs/BundleAnchor"
        },
        "author": {
          "$ref": "#/$defs/BundleAuthor"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "text": {
          "type": "string"
        },
        "replyTo": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "anchor",
        "createdAt",
        "text"
      ]
    },
    "BundleAuthor": {
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "BundleBookmark": {
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "anchor": {
          "$ref": "#/$defs/BundleAnchor"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "title",
        "anchor"
      ]
    },
    "BundleChatBoundary": {
      "properties": {
        "chatId": {
          "type": "integer"
        },
        "firstEntry": {
          "type": "integer"
        },
        "entryCount": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "chatId",
        "firstEntry",
        "entryCount"
      ]
    },
    "BundleChatJournal": {
      "properties": {
        "chatId": {
          "type": "integer"
        },
        "entries": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/PlatformJournalEntry"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "chatId",
        "entries"
      ]
    },
    "BundleJournalBoundary": {
      "properties": {
        "chats": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/BundleChatBoundary"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "chats"
      ]
    },
    "BundleMetadata": {
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "chatwrightVersion": {
          "type": "string"
        },
        "author": {
          "$ref": "#/$defs/BundleAuthor"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "createdAt"
      ]
    },
    "BundlePart": {
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "journalBoundary": {
          "$ref": "#/$defs/BundleJournalBoundary"
        },
        "aiGoal": {
          "$ref": "#/$defs/BundleAIGoalSection"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "kind",
        "journalBoundary"
      ]
    },
    "BundlePlatformIdentity": {
      "properties": {
        "userId": {
          "type": "integer"
        },
        "username": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "userId"
      ]
    },
    "BundleRetainedObservation": {
      "properties": {
        "sequence": {
          "type": "integer"
        },
        "observation": {
          "$ref": "#/$defs/ObserveObservation"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "sequence",
        "observation"
      ]
    },
    "BundleRun": {
      "properties": {
        "id": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "endpointProfile": {
          "type": "string"
        },
        "actors": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/BundleActor"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "chats": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/BundleChatJournal"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "parts": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/BundlePart"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "bookmarks": {
          "items": {
            "$ref": "#/$defs/BundleBookmark"
          },
          "type": "array"
        },
        "annotations": {
          "items": {
            "$ref": "#/$defs/BundleAnnotation"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "platform",
        "endpointProfile",
        "actors",
        "chats",
        "parts"
      ]
    },
    "CampaignAggregateUsage": {
      "properties": {
        "inputTokens": {
          "type": "integer"
        },
        "outputTokens": {
          "type": "integer"
        },
        "cost": {
          "type": "number"
        },
        "callCount": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "inputTokens",
        "outputTokens",
        "callCount"
      ]
    },
    "CampaignEvidence": {
      "properties": {
        "observationSequences": {
          "items": {
            "type": "integer"
          },
          "type": "array"
        },
        "loopEventIndexes": {
          "items": {
            "type": "integer"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "CampaignFinding": {
      "properties": {
        "kind": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/CampaignEvidence"
        },
        "confidence": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "kind",
        "taskId",
        "summary",
        "evidence"
      ]
    },
    "CampaignReport": {
      "properties": {
        "schemaVersion": {
          "type": "integer"
        },
        "goalId": {
          "type": "string"
        },
        "goalTitle": {
          "type": "string"
        },
        "stopReason": {
          "type": "string"
        },
        "steps": {
          "type": "integer"
        },
        "cost": {
          "type": "number"
        },
        "elapsedNanoseconds": {
          "type": "integer"
        },
        "tasks": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/CampaignTaskOutcome"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "findings": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/CampaignFinding"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "usage": {
          "$ref": "#/$defs/CampaignAggregateUsage"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schemaVersion",
        "goalId",
        "goalTitle",
        "stopReason",
        "steps",
        "elapsedNanoseconds",
        "tasks",
        "findings",
        "usage"
      ]
    },
    "CampaignTaskOutcome": {
      "properties": {
        "taskId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "successCriteria": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "attempted": {
          "type": "boolean"
        },
        "failureCount": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "taskId",
        "status",
        "attempted",
        "failureCount"
      ]
    },
    "DatastateEvidence": {
      "properties": {
        "Name": {
          "type": "string"
        },
        "AttachmentPoint": {
          "type": "string"
        },
        "Holder": {
          "type": "string"
        },
        "Query": {
          "type": "string"
        },
        "Params": {
          "oneOf": [
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ]
        },
        "Outcome": {
          "type": "string"
        },
        "FailureMessage": {
          "type": "string"
        },
        "TotalRows": {
          "type": "integer"
        },
        "ReturnedRows": {
          "type": "integer"
        },
        "Truncated": {
          "type": "boolean"
        },
        "Preview": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/DatastateRow"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "RedactedFields": {
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "ExcludedFields": {
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "Name",
        "AttachmentPoint",
        "Holder",
        "Query",
        "Params",
        "Outcome",
        "FailureMessage",
        "TotalRows",
        "ReturnedRows",
        "Truncated",
        "Preview",
        "RedactedFields",
        "ExcludedFields"
      ]
    },
    "DatastateRow": {
      "type": "object"
    },
    "GoalBudgets": {
      "properties": {
        "MaxSteps": {
          "type": "integer"
        },
        "MaxDuration": {
          "type": "integer"
        },
        "MaxRepeatedFailures": {
          "type": "integer"
        },
        "MaxCost": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "MaxSteps",
        "MaxDuration",
        "MaxRepeatedFailures",
        "MaxCost"
      ]
    },
    "GoalGoal": {
      "properties": {
        "ID": {
          "type": "string"
        },
        "Title": {
          "type": "string"
        },
        "Description": {
          "type": "string"
        },
        "Tasks": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/GoalTask"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "Constraints": {
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "Budgets": {
          "$ref": "#/$defs/GoalBudgets"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ID",
        "Title",
        "Description",
        "Tasks",
        "Constraints",
        "Budgets"
      ]
    },
    "GoalTask": {
      "properties": {
        "ID": {
          "type": "string"
        },
        "Title": {
          "type": "string"
        },
        "DependsOn": {
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "SuccessCriteria": {
          "type": "string"
        },
        "Milestones": {
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ID",
        "Title",
        "DependsOn",
        "SuccessCriteria",
        "Milestones"
      ]
    },
    "ObserveAvailableAction": {
      "properties": {
        "ID": {
          "type": "string"
        },
        "Label": {
          "type": "string"
        },
        "SeenAt": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ID",
        "Label",
        "SeenAt"
      ]
    },
    "ObserveChange": {
      "properties": {
        "Kind": {
          "type": "string",
          "enum": [
            "new-message",
            "edited-message",
            "actions-changed"
          ]
        },
        "MessageID": {
          "type": "string"
        },
        "Actor": {
          "type": "string",
          "enum": [
            "user",
            "bot"
          ]
        },
        "PreviousVersion": {
          "type": "integer"
        },
        "Version": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "Kind",
        "MessageID",
        "Actor",
        "PreviousVersion",
        "Version"
      ]
    },
    "ObserveChatRef": {
      "properties": {
        "ChatID": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ChatID"
      ]
    },
    "ObserveObservation": {
      "properties": {
        "Sequence": {
          "type": "integer"
        },
        "PreviousSequence": {
          "type": "integer"
        },
        "Chat": {
          "$ref": "#/$defs/ObserveChatRef"
        },
        "Messages": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/ObserveVisibleMessage"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "Changes": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/ObserveChange"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "Sequence",
        "PreviousSequence",
        "Chat",
        "Messages",
        "Changes"
      ]
    },
    "ObserveVisibleMessage": {
      "properties": {
        "ID": {
          "type": "string"
        },
        "Version": {
          "type": "integer"
        },
        "Edited": {
          "type": "boolean"
        },
        "Actor": {
          "type": "string",
          "enum": [
            "user",
            "bot"
          ]
        },
        "Text": {
          "type": "string"
        },
        "Actions": {
          "oneOf": [
            {
              "items": {
                "$ref": "#/$defs/ObserveAvailableAction"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "ID",
        "Version",
        "Edited",
        "Actor",
        "Text",
        "Actions"
      ]
    },
    "PlatformAction": {
      "properties": {
        "Label": {
          "type": "string"
        },
        "ID": {
          "type": "string"
        },
        "URL": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "Label",
        "ID",
        "URL"
      ]
    },
    "PlatformJournalEntry": {
      "properties": {
        "Direction": {
          "type": "string",
          "enum": [
            "user",
            "bot"
          ]
        },
        "Kind": {
          "type": "string",
          "enum": [
            "message",
            "action",
            "uncaptured"
          ]
        },
        "MessageID": {
          "type": "integer"
        },
        "RefMessageID": {
          "type": "integer"
        },
        "Version": {
          "type": "integer"
        },
        "Text": {
          "type": "string"
        },
        "Actions": {
          "oneOf": [
            {
              "items": {
                "items": {
                  "$ref": "#/$defs/PlatformAction"
                },
                "type": "array"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "Method": {
          "type": "string"
        },
        "At": {
          "type": "string",
          "format": "date-time"
        },
        "FromID": {
          "type": "integer"
        }

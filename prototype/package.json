{
  "name": "chatwright-studio-prototype",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "ng": "ng",
    "prepare:config": "node scripts/prepare-local-config.mjs",
    "start": "pnpm prepare:config && ng serve --host 127.0.0.1",
    "build": "pnpm prepare:config && ng build",
    "build:dev": "pnpm prepare:config && ng build --configuration development",
    "typecheck": "pnpm prepare:config && ng build --configuration development"
  },
  "dependencies": {
    "@angular/cdk": "22.0.5",
    "@angular/common": "22.0.7",
    "@angular/compiler": "22.0.7",
    "@angular/core": "22.0.7",
    "@angular/forms": "22.0.7",
    "@angular/platform-browser": "22.0.7",
    "@angular/router": "22.0.7",
    "@primeuix/themes": "3.0.0",
    "highlight.js": "11.11.1",
    "primeicons": "^7.0.0",
    "primeng": "22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.7",
    "@angular/cli": "22.0.7",
    "@angular/compiler-cli": "22.0.7",
    "typescript": "~6.0.3"
  }
}
